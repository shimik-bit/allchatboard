{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": [
    "fra1"
  ],
  "functions": {
    "app/api/whatsapp/webhook/route.ts": {
      "maxDuration": 30
    },
    "app/api/reports/cron/route.ts": {
      "maxDuration": 60
    },
    "app/api/billing/cron/route.ts": {
      "maxDuration": 300
    },
    "app/api/workflows/scheduled-cron/route.ts": {
      "maxDuration": 60
    },
    "app/api/health/check/route.ts": {
      "maxDuration": 60
    },
    "app/api/groupguard/profiles/extract-cron/route.ts": {
      "maxDuration": 60
    },
    "app/api/groupguard/profiles/rescan/route.ts": {
      "maxDuration": 60
    },
    "app/api/groupguard/groups/[id]/summarize/route.ts": {
      "maxDuration": 60
    },
    "app/api/groupguard/summaries/cron/route.ts": {
      "maxDuration": 60
    },
    "app/api/whatsapp/recover/route.ts": {
      "maxDuration": 60
    },
    "app/api/whatsapp/recover-cron/route.ts": {
      "maxDuration": 300
    },
    "app/api/groupguard/profiles/avatars-backfill/route.ts": {
      "maxDuration": 120
    },
    "app/api/groupguard/profiles/avatars-backfill-cron/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/billing/cron",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/workflows/scheduled-cron",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/groupguard/profiles/extract-cron",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/groupguard/summaries/cron",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/whatsapp/recover-cron",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/groupguard/profiles/avatars-backfill-cron",
      "schedule": "30 3 * * *"
    }
  ]
}