{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": [
    "fra1"
  ],
  "functions": {
    "app/api/whatsapp/webhook/route.ts": {
      "maxDuration": 30
    },
    "app/api/reports/cron/route.ts": {
      "maxDuration": 60
    },
    "app/api/billing/cron/route.ts": {
      "maxDuration": 300
    },
    "app/api/workflows/scheduled-cron/route.ts": {
      "maxDuration": 60
    },
    "app/api/health/check/route.ts": {
      "maxDuration": 60
    },
    "app/api/whatsapp/dispatcher/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/billing/cron",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/workflows/scheduled-cron",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/whatsapp/dispatcher",
      "schedule": "0 4 * * *"
    }
  ]
}